";
async function convertAndPlay() {
    const status = document.getElementById('status');
    const progress = document.getElementById('progressBar');
    const video = document.getElementById('videoPlayer');
    try {
        status.innerText = "Processing Video Data...";
        const binary = atob(base64Data);
        const array = new Uint8Array(binary.length);
        for (let i = 0; i < binary.length; i++) {
            array[i] = binary.charCodeAt(i);
            if (i % 500000 === 0) progress.style.width = ((i / binary.length) * 100) + "%";
        }
        const blob = new Blob([array], { type: 'video/mp4' });
        video.src = URL.createObjectURL(blob);
        document.getElementById('pContainer').style.display = "none";
        video.style.display = "block";
        status.innerText = "Ready";
    } catch (e) { status.innerText = "Error: " + e.message; }
}
window.onload = convertAndPlay;
</script>
</body>
</html>
